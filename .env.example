# ──────────────────────────────────────────────────────────────────────────
# Lettersprite blog — per-deployment configuration
#
# One codebase, deployed many times. Each blog is differentiated ONLY by these
# variables — there is no database and no admin panel. For local development,
# copy this file to `.env.local`. For production, set the same keys as
# Environment Variables in each Vercel project. Changing a value requires a
# redeploy (content and config are baked in at build time — there are no
# runtime API calls and no revalidation window).
# ──────────────────────────────────────────────────────────────────────────

# ── Content source (Letterbrace) ──────────────────────────────────────────
# API key for the collection this blog renders. Create one in Letterbrace →
# Settings → API Keys with the `article:read` capability. Without it, the blog
# renders a set of sample stories (a live theme preview) and is marked noindex.
LETTERBRACE_API_KEY=lb_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Override only when pointing at a non-default Letterbrace host.
LETTERBRACE_API_URL=https://app.letterstory.com/api/integrations
# Optional: scope this blog to a single collection within the org.
# LETTERBRACE_COLLECTION_ID=00000000-0000-0000-0000-000000000000

# ── Theme selection ───────────────────────────────────────────────────────
# Each theme is a full publication look — palette, fonts, masthead, homepage
# layout and logo treatment. One of:
#   sleek | classic | minimal | magazine | midnight        (clean baselines)
#   gazette | dispatch | metro | review | signal | current
#   ledger  | atelier  | noir  | chronicle                  (magazine fronts)
# See src/themes. Add your own by copying src/themes/sleek.ts.
THEME=gazette

# ── Site identity ─────────────────────────────────────────────────────────
SITE_TITLE=Your Publication Name
# A short standfirst shown under the wordmark and in the footer.
SITE_TAGLINE=Ideas, technology & culture
SITE_DESCRIPTION=Independent reporting on the ideas shaping tomorrow.
# Founding year, shown as "Est. 2024" in the footer. Optional.
SITE_ESTABLISHED=2024
# Social handle (no @). Powers the Twitter/X card attribution + footer link.
SITE_TWITTER=yourhandle
# Comma-separated profile/entity URLs for the Organization's schema.org sameAs
# (LinkedIn, Wikipedia, Crunchbase, …). The X/Twitter profile from SITE_TWITTER
# is added automatically. Optional.
# SITE_SAME_AS=https://www.linkedin.com/company/acme,https://en.wikipedia.org/wiki/Acme
# Public base URL, no trailing slash. On Vercel it is auto-detected from
# VERCEL_PROJECT_PRODUCTION_URL when omitted, but set it explicitly for correct
# canonical URLs, OpenGraph tags, RSS and the sitemap.
SITE_URL=https://example.com

# ── Industry theming ──────────────────────────────────────────────────────
# Set this to your deployment's industry vertical. Lettersprite will automatically
# select the best-fit theme and palette for that industry. Any explicit THEME or
# SITE_*_COLOR override always wins. Supported values:
#   healthcare | fintech | legal | tech | retail | realestate
#   education  | food    | travel | hr  | marketing | sustainability
# SITE_INDUSTRY=healthcare

# ── Section navigation ─────────────────────────────────────────────────────
# Comma-separated masthead nav. Omit to derive it automatically from the most
# common post tags/sections.
# SITE_SECTIONS=Technology, Business, Culture, Science, Ideas

# ── Palette + font overrides (layered on top of the selected theme) ────────
# Supply a whole color palette — not just text and background — so the theme's
# dynamic visuals (hero gradients, tinted bands, colored kickers, pills) recolor
# coherently. Any CSS color works. IMPORTANT: quote hex values in a shell/.env
# (a bare leading '#' is read as a comment) — `SITE_ACCENT_COLOR="#dc2626"`.
# SITE_ACCENT_COLOR="#4f46e5"      # primary brand accent (buttons, active nav)
# SITE_SECONDARY_COLOR="#0ea5e9"   # second brand color (links, hover)
# SITE_POP_COLOR="#ec4899"         # highlight/pill/kicker pop color
# SITE_BACKGROUND_COLOR="#ffffff"
# SITE_SURFACE_COLOR="#f6f6f7"
# SITE_TEXT_COLOR="#0f0f10"
# SITE_HEADING_COLOR="#0f0f10"
# SITE_LINK_COLOR="#4f46e5"
# SITE_HERO_FROM="#6366f1"         # hero gradient start
# SITE_HERO_TO="#8b5cf6"           # hero gradient end
# Swap fonts without authoring a theme. Any Google Fonts family (weights 400/700).
# FONT_DISPLAY=Playfair Display    # big headlines / wordmark
# FONT_HEADING=Libre Franklin      # section headings, nav, kickers
# FONT_BODY=Source Serif 4         # article body
# Force a logo treatment: serif | sans-bold | condensed | mono | boxed |
# underline | monogram | initial. Otherwise the theme decides.
# "initial" renders the first letter of SITE_TITLE as an oversized masthead mark
# with the full name in smaller type beside it — a real logotype, not a placeholder.
# SITE_LOGO_STYLE=serif
# Inline logo SVG. When set, the masthead renders this SVG instead of the
# typographic wordmark (SITE_LOGO_STYLE is then ignored). Pass the raw
# <svg>…</svg> markup itself — NOT a URL. It's inlined directly; <script> and
# on* handlers are stripped. Height is fixed per masthead size and width scales
# to the SVG's aspect ratio, so put a viewBox on the source. Use `currentColor`
# for fills/strokes to inherit the theme's heading color. Keep it on ONE line
# in .env (strip internal newlines). Alt text defaults to SITE_TITLE.
# SITE_LOGO_SVG='<svg viewBox="0 0 120 24" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="..."/></svg>'
# SITE_LOGO_ALT=Acme Weekly

# ── Newsletter ─────────────────────────────────────────────────────────────
# Subscribe capture is designed but OFF by default (no working backend yet).
# Turn it on only once it can actually collect emails: set NEWSLETTER_ENABLED
# and point NEWSLETTER_ACTION at a real provider (Mailchimp, Buttondown, …).
# NEWSLETTER_ENABLED=true
# NEWSLETTER_ACTION=https://your-provider.example/subscribe

# ── Direct payload ingestion ──────────────────────────────────────────────
# Zero-integration content path: write posts to content/payload.json and trigger
# a rebuild — no Letterbrace setup required. Can be used alongside or instead of
# the Letterbrace API; posts from both sources are merged and deduped by id.
# PAYLOAD_ENABLED=true
# Path to the payload file, relative to the repo root (default shown).
# PAYLOAD_FILE=content/payload.json
# The payload may also carry a single "whyChoose" object (same shape as a post).
# When present it powers the /why "Why companies choose X" page — an impartial,
# third-party editorial write-up — and is kept off the feed, sections and RSS.

# ── Content behaviour ─────────────────────────────────────────────────────
# The blog is fully static: the Letterbrace payload is baked in at build time,
# so updating content means triggering a new build (no runtime API calls).
# Max posts fetched for the index (1–100).
POSTS_LIMIT=50
# Include draft-status posts (default false).
SHOW_DRAFTS=false
