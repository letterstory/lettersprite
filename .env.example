# ──────────────────────────────────────────────────────────────────────────
# Letterbrace blog — per-deployment configuration
#
# One codebase, deployed many times. Each blog is differentiated ONLY by these
# variables — there is no database and no admin panel. For local development,
# copy this file to `.env.local`. For production, set the same keys as
# Environment Variables in each Vercel project. Changing a value requires a
# redeploy (or waiting out the ISR window) to take effect.
# ──────────────────────────────────────────────────────────────────────────

# ── Content source (Letterbrace) ──────────────────────────────────────────
# API key for the collection this blog renders. Create one in Letterbrace →
# Settings → API Keys with the `article:read` capability. Without it, the blog
# renders an empty state instead of crashing.
LETTERBRACE_API_KEY=lb_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Override only when pointing at a non-default Letterbrace host.
LETTERBRACE_API_URL=https://app.letterbrace.com/api/integrations
# Optional: scope this blog to a single collection within the org.
# LETTERBRACE_COLLECTION_ID=00000000-0000-0000-0000-000000000000

# ── Theme selection ───────────────────────────────────────────────────────
# One of: sleek | classic | minimal | magazine | midnight   (see src/themes).
# Add your own by copying src/themes/sleek.ts, then select it here.
THEME=sleek

# ── Site identity ─────────────────────────────────────────────────────────
SITE_TITLE=My Blog
SITE_DESCRIPTION=Thoughts, stories, and ideas.
# Public base URL, no trailing slash. On Vercel it is auto-detected from
# VERCEL_PROJECT_PRODUCTION_URL when omitted, but set it explicitly for correct
# canonical URLs, OpenGraph tags and the sitemap.
SITE_URL=https://example.com

# ── Optional overrides (layered on top of the selected theme) ──────────────
# Fine-grained site colors, layered on top of the selected theme's palette.
# IMPORTANT: quote hex values. An unquoted leading '#' is read as a comment, so
# `SITE_BACKGROUND_COLOR=#000` is ignored — write `SITE_BACKGROUND_COLOR="#000"`.
# SITE_BACKGROUND_COLOR="#ffffff"
# SITE_TEXT_COLOR="#0f0f10"
# SITE_HEADING_COLOR="#0f0f10"
# SITE_LINK_COLOR="#4f46e5"
# SITE_ACCENT_COLOR="#4f46e5"     # accent: buttons, tags, "read more"
# Swap fonts without authoring a new theme. Any Google Fonts family name works;
# weights 400 and 700 are loaded.
# FONT_BODY=Inter
# FONT_HEADING=Poppins

# ── Content behaviour ─────────────────────────────────────────────────────
# The blog is fully static: the Letterbrace payload is baked in at build time,
# so updating content means triggering a new build (no runtime API calls).
# Max posts fetched for the index (1–100).
POSTS_LIMIT=50
# Include draft-status posts (default false).
SHOW_DRAFTS=false
